# ============================================================
# Moon Tracker — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Supabase (optional — app works fully offline without this)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# No other env vars are required.
# Moon calculations run entirely client-side via SunCalc.
# Geocoding uses the free OpenStreetMap Nominatim API (no key).
# ============================================================
